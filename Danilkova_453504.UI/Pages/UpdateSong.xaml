<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Danilkova_453504.UI.Pages.UpdateSong"
             Title="UpdateSong">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Update Song" FontSize="20" FontAttributes="Bold" />

        <Entry Placeholder="Name" 
        Text="{Binding Name}" />

        <Entry Placeholder="Cont (example, 3.45)" 
        Text="{Binding Continuation}" 
        Keyboard="Numeric" />

        <Entry Placeholder="Genre" 
        Text="{Binding Genre}" />

        <Entry Placeholder="Rate (1-10)" 
        Text="{Binding Rate}" 
        Keyboard="Numeric" />

        <Button Text="Update" 
         Command="{Binding UpdateSongCommand}" 
         BackgroundColor="Green" 
         TextColor="White" />

       
    </VerticalStackLayout>
</ContentPage>