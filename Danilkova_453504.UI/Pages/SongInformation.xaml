<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Danilkova_453504.UI.Pages.SongInformation"
             xmlns:models="clr-namespace:Danilkova_453504.UI.ViewModels"
             x:DataType="models:SongInformationViewModel"
             xmlns:conv="clr-namespace:Danilkova_453504.UI.ValueConverters"
             Title="SongInformation">


    <ContentPage.Resources>
        <conv:IdToImageConverter x:Key="IdToImage" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit Photo" Command="{Binding PickImageOnPageCommand}" />
        <ToolbarItem Text="Edit" Command="{Binding UpdateSongOnPageCommand}" />
        <ToolbarItem Text="Delete" Command="{Binding DeleteSongOnPageCommand}" />
    </ContentPage.ToolbarItems>

    
    <VerticalStackLayout Padding="20" Spacing="10">
        <Frame Margin="0,10"
                   Padding="10" 
                   CornerRadius="8" 
                   HasShadow="True" 
                   BorderColor="LightGray"
                   HorizontalOptions="Center"
                   BackgroundColor="White">

            <Image Source="{Binding SongId, Converter={StaticResource IdToImage}}"
                       HeightRequest="250"
                       WidthRequest="250"
                       Aspect="AspectFill">
                
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding PickImageOnPageCommand}" />
                </Image.GestureRecognizers>
            </Image>
        </Frame>

        <Frame BackgroundColor="#F8F8F8" CornerRadius="10" BorderColor="#E0E0E0" Padding="15">
            <VerticalStackLayout Spacing="10">
                <Label Text="Assign Singer" FontSize="14" FontAttributes="Bold" TextColor="MediumPurple" />

                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                    <Picker Grid.Column="0"
                                Title="Select singer..."
                                ItemsSource="{Binding Singers}"
                                ItemDisplayBinding="{Binding Name}" 
                                SelectedItem="{Binding SelectedSinger}"
                                VerticalOptions="Center" />

                    <Button Grid.Column="1"
                                Text="Apply"
                                Command="{Binding AlterSingerOfSongCommand}"
                                BackgroundColor="MediumPurple"
                                TextColor="White"
                                HeightRequest="40"
                                Padding="15,0" />
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <Label Text="{Binding Song.SongInformation.Name}" 
               FontSize="28" 
               FontAttributes="Bold" 
               HorizontalOptions="Center" />

        <BoxView HeightRequest="1" Color="Gray" Margin="0,10" />

        
        <HorizontalStackLayout Spacing="5">
            <Label Text="Genre:" FontAttributes="Bold" />
            <Label Text="{Binding Song.SongInformation.Genre}" />
        </HorizontalStackLayout>

       
        <HorizontalStackLayout Spacing="5">
            <Label Text="Duration:" FontAttributes="Bold" />
            <Label Text="{Binding Song.SongInformation.Continuation, StringFormat='{0} min'}" />
        </HorizontalStackLayout>

        
        <HorizontalStackLayout Spacing="5">
            <Label Text="Rating:" FontAttributes="Bold" />
            <Label Text="{Binding Song.Rate, StringFormat='{0}/100'}" 
                   TextColor="DarkGreen" />
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>