<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Danilkova_453504.UI.Pages.CreateSinger"
             xmlns:models="clr-namespace:Danilkova_453504.UI.ViewModels"
             
             Title="New Artist"
             BackgroundColor="#121212"
             Shell.BackgroundColor="#121212"
             Shell.ForegroundColor="White">

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto, Auto, *" Padding="10,0,20,0" ColumnSpacing="20">

            <!-- Кнопка Назад/Отмена (имитация) -->
            <Label Grid.Column="0"
                   Text="Cancel"
                   TextColor="#FF5252" 
                   FontAttributes="Bold"
                   FontSize="14"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <!-- Используем стандартный переход назад, если нет специальной команды -->
                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=Navigation.PopAsync}" />
                </Label.GestureRecognizers>
            </Label>

            
           

            <!-- Логотип MUSIC -->
            <Label Grid.Column="2" 
                   Text="MUSIC" 
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="18"
                   VerticalOptions="Center"
                   HorizontalOptions="End" 
                   CharacterSpacing="2"/>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

            <Label Text="ADD NEW SINGER" 
                   TextColor="#1DB954" 
                   FontSize="12" 
                   FontAttributes="Bold" 
                   CharacterSpacing="2"
                   HorizontalOptions="Center"
                   Margin="0,10,0,10"/>

            <!-- Поле: Имя исполнителя -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Artist Name" TextColor="#8E8E93" FontSize="13" Margin="5,0"/>
                <Border BackgroundColor="#252525" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="15,0">
                    <Entry Text="{Binding Name}" 
                           Placeholder="Enter name..." 
                           PlaceholderColor="#555555"
                           TextColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Поле: Возраст -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Age" TextColor="#8E8E93" FontSize="13" Margin="5,0"/>
                <Border BackgroundColor="#252525" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="15,0">
                    <Entry Text="{Binding Age}" 
                           Placeholder="e.g. 25" 
                           Keyboard="Numeric"
                           PlaceholderColor="#555555"
                           TextColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Поле: Страна -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Country" TextColor="#8E8E93" FontSize="13" Margin="5,0"/>
                <Border BackgroundColor="#252525" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="15,0">
                    <Entry Text="{Binding Country}" 
                           Placeholder="e.g. USA, UK" 
                           PlaceholderColor="#555555"
                           TextColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Большая кнопка Сохранить -->
            <Button Text="SAVE SINGER" 
                    Command="{Binding SaveSingerCommand}" 
                    BackgroundColor="#1DB954" 
                    TextColor="Black"
                    FontAttributes="Bold"
                    CornerRadius="25"
                    HeightRequest="50"
                    Margin="0,30,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>