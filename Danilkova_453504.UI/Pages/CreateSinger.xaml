<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Danilkova_453504.UI.Pages.CreateSinger"
             Title="Create Singer">
    
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Add new singer" FontSize="20" FontAttributes="Bold" />

        <Entry Placeholder="Name of singer" 
       Text="{Binding Name}" />

        <Entry Placeholder="Age" 
       Text="{Binding Age}" 
       Keyboard="Numeric" />

        <Entry Placeholder="Country" 
       Text="{Binding Country}" />

        <Button Text="Save" 
        Command="{Binding SaveSingerCommand}" 
        BackgroundColor="Green" 
        TextColor="White" />

        
    </VerticalStackLayout>
</ContentPage>