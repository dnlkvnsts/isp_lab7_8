<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Danilkova_453504.UI.Pages.CreateSongForSinger"
             Title="New Song"
             BackgroundColor="#121212"
             Shell.BackgroundColor="#121212"
             Shell.ForegroundColor="White">

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto, Auto, *" Padding="10,0,20,0" ColumnSpacing="20">

            <!-- Кнопка Отмена -->
            <Label Grid.Column="0"
                   Text="Cancel"
                   TextColor="#FF5252" 
                   FontAttributes="Bold"
                   FontSize="14"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CancelCommand}" />
                </Label.GestureRecognizers>
            </Label>

        

            <!-- Логотип MUSIC -->
            <Label Grid.Column="2" 
                   Text="MUSIC" 
                   TextColor="White"
                   FontAttributes="Bold"
                   FontSize="18"
                   VerticalOptions="Center"
                   HorizontalOptions="End" 
                   CharacterSpacing="2"/>
        </Grid>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

            <!-- Заголовок страницы -->
            <Label Text="ADD NEW SONG" 
                   TextColor="#1DB954" 
                   FontSize="12" 
                   FontAttributes="Bold" 
                   CharacterSpacing="2"
                   HorizontalOptions="Center"
                   Margin="0,10,0,10"/>

            <!-- Поле: Название -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Song Name" TextColor="#8E8E93" FontSize="13" Margin="5,0"/>
                <Border BackgroundColor="#252525" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="15,0">
                    <Entry Text="{Binding Name}" 
                           Placeholder="Enter title..." 
                           PlaceholderColor="#555555"
                           TextColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Поле: Длительность -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Duration (min)" TextColor="#8E8E93" FontSize="13" Margin="5,0"/>
                <Border BackgroundColor="#252525" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="15,0">
                    <Entry Text="{Binding Continuation}" 
                           Placeholder="e.g. 3.45" 
                           Keyboard="Numeric"
                           PlaceholderColor="#555555"
                           TextColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Поле: Жанр -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Genre" TextColor="#8E8E93" FontSize="13" Margin="5,0"/>
                <Border BackgroundColor="#252525" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="15,0">
                    <Entry Text="{Binding Genre}" 
                           Placeholder="Pop, Rock, etc." 
                           PlaceholderColor="#555555"
                           TextColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Поле: Рейтинг -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Rating (1-100)" TextColor="#8E8E93" FontSize="13" Margin="5,0"/>
                <Border BackgroundColor="#252525" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="15,0">
                    <Entry Text="{Binding Rate}" 
                           Placeholder="Score..." 
                           Keyboard="Numeric"
                           PlaceholderColor="#555555"
                           TextColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- Большая кнопка Сохранить внизу (дублирующая) -->
            <Button Text="SAVE SONG" 
                    Command="{Binding SaveSongCommand}" 
                    BackgroundColor="#1DB954" 
                    TextColor="Black"
                    FontAttributes="Bold"
                    CornerRadius="25"
                    HeightRequest="50"
                    Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>