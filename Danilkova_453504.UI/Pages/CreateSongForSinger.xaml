<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Danilkova_453504.UI.Pages.CreateSongForSinger"
             Title="CreateSongForSinger">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Добавление новой песни" FontSize="20" FontAttributes="Bold" />

        <Entry Placeholder="Название песни" 
           Text="{Binding Name}" />

        <Entry Placeholder="Длительность (например, 3.45)" 
           Text="{Binding Continuation}" 
           Keyboard="Numeric" />

        <Entry Placeholder="Жанр" 
           Text="{Binding Genre}" />

        <Entry Placeholder="Рейтинг (1-10)" 
           Text="{Binding Rate}" 
           Keyboard="Numeric" />

        <Button Text="Сохранить" 
            Command="{Binding SaveSongCommand}" 
            BackgroundColor="Green" 
            TextColor="White" />

        <Button Text="Отмена" 
            Command="{Binding CancelCommand}" 
            BackgroundColor="Gray" />
    </VerticalStackLayout>
</ContentPage>